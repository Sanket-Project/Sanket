# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://sanket_app:changeme@localhost:5432/sanket

# Pool settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_ECHO=false

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-64-char-random-secret-before-deploying
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=false
APP_NAME=SANKET
APP_VERSION=0.1.0
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Security ─────────────────────────────────────────────────────────────────
ARGON2_TIME_COST=3
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=4

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Optional: TimescaleDB hypertable conversion ───────────────────────────────
TIMESCALEDB_ENABLED=false

# ── ML inference service ─────────────────────────────────────────────────────
ML_API_URL=http://localhost:8001
# Shared bearer the backend presents to the internal ML service. Leave blank in
# dev to fall back to JWT_SECRET (the ML service must use the same value via its
# ML_SERVICE_TOKEN). REQUIRED in production — the ML service rejects unsigned
# requests (fail-closed).
ML_SERVICE_TOKEN=

# ── Firebase auth tuning ────────────────────────────────────────────────
FIREBASE_PROJECT_ID=
# OPTION A: Filesystem path (local dev only — never commit the JSON file)
FIREBASE_CREDENTIALS_PATH=
# OPTION B (preferred for production / Cloud Run / Kubernetes):
#   base64-encode the service account JSON, paste the output here.
#   On Linux/macOS: base64 -w0 path/to/firebase-credentials.json
#   On macOS:       base64 -i path/to/firebase-credentials.json
# This avoids hardcoded filesystem paths that break in containers.
FIREBASE_CREDENTIALS_JSON=
FIREBASE_WEB_API_KEY=
# Per-request revocation check is a network round-trip to Firebase. Off by
# default (ID tokens are short-lived); enable only if immediate revocation is a
# hard requirement and the latency/availability cost is acceptable.
FIREBASE_CHECK_REVOKED=false

# ── Optional: External signal sources ────────────────────────────────────────
GOOGLE_TRENDS_API_KEY=
WEATHER_API_KEY=

# ── Billing (Razorpay) ───────────────────────────────────────────────────────
# Dashboard → Settings → API Keys (use rzp_test_* for the test environment)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Dashboard → Settings → Webhooks → the secret you set when creating the webhook
RAZORPAY_WEBHOOK_SECRET=

# ── Observability ─────────────────────────────────────────────────────────────
# Token to protect GET /metrics from unauthenticated access.
# REQUIRED in production. Generate: openssl rand -hex 24
METRICS_TOKEN=
# Token for GET /health/detailed from ops tooling (X-Internal-Token header).
# Generate: openssl rand -hex 24
OPS_HEALTH_TOKEN=

# ── Deployment ────────────────────────────────────────────────────────────────
# Number of uvicorn worker processes (default 4 for production).
WORKERS=4
# CIDR of your load balancer / reverse proxy for X-Forwarded-For trust.
# WARNING: Do NOT set to '*' — use the actual LB network CIDR.
# Examples: "10.0.0.0/8" (GCP internal), "172.16.0.0/12" (AWS internal)
FORWARDED_ALLOW_IPS=127.0.0.1

# ── Grafana (docker-compose only) ─────────────────────────────────────────────
# REQUIRED when using docker-compose. Generate: openssl rand -base64 20
GRAFANA_PASSWORD=

# ── Phase 1 hardening: security ───────────────────────────────────────────────
# Enforce Firebase token revocation (logout/disable/password-reset take effect
# within the cache TTL instead of the full ~1h ID-token lifetime). Default on.
FIREBASE_CHECK_REVOKED=true
FIREBASE_REVOCATION_CACHE_TTL_S=60
# Inbound webhook replay protection (freshness window + delivery-id dedupe).
WEBHOOK_REPLAY_PROTECTION_ENABLED=true
WEBHOOK_REPLAY_MAX_AGE_S=300
WEBHOOK_REPLAY_DEDUPE_TTL_S=900
# Request idempotency (Idempotency-Key header → cached response on retry).
# Requires REDIS_URL to work across replicas.
IDEMPOTENCY_ENABLED=true
IDEMPOTENCY_TTL_S=86400
# Dedicated secret for encrypting third-party tokens at rest (else derived from
# JWT_SECRET). Generate: openssl rand -hex 32
INTEGRATION_ENCRYPTION_KEY=

# ── Phase 1 hardening: database (PgBouncer / HA) ──────────────────────────────
# Set true when DATABASE_URL points at PgBouncer in transaction pooling mode
# (production). Disables asyncpg server-side prepared statements (pooler-safe).
DB_PGBOUNCER_MODE=false

# ── Phase 1 hardening: background-worker leader election ──────────────────────
# Singleton background loops (signal ingest, Shopify poller, webhook retry) run
# on exactly one replica via a Redis leader lease. No-op without REDIS_URL.
WORKER_LEADER_LOCK_TTL_S=30
WORKER_LEADER_RENEW_INTERVAL_S=10

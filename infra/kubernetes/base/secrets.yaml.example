# ──────────────────────────────────────────────────────────────────────────────
# secrets.yaml.example — TEMPLATE ONLY, never commit secrets.yaml with real values.
#
# Bootstrap real secrets on the cluster instead:
#
#   STAGING:
#   kubectl create secret generic sanket-secrets \
#     --from-literal=POSTGRES_PASSWORD=<password> \
#     --from-literal=JWT_SECRET=<64-char-random> \
#     --from-literal=ML_SERVICE_TOKEN=<64-char-random> \
#     -n sanket-staging
#
#   kubectl create secret generic sanket-db-url \
#     --from-literal=DATABASE_URL="postgresql+asyncpg://sanket_app:<pw>@postgres-pooler-rw:5432/sanket" \
#     --from-literal=ML_DATABASE_URL="postgresql://sanket_app:<pw>@postgres-rw:5432/sanket" \
#     --from-literal=DATABASE_URL_DIRECT="postgresql+asyncpg://sanket_app:<pw>@postgres-rw:5432/sanket" \
#     -n sanket-staging
#
#   Repeat with -n sanket for PRODUCTION.
#
# This file documents the required keys only. The real secrets.yaml is gitignored.
# ──────────────────────────────────────────────────────────────────────────────
apiVersion: v1
kind: Secret
metadata:
  name: sanket-secrets
  namespace: sanket
type: Opaque
stringData:
  # Superuser password — used by migrations and the backup job (which must
  # bypass RLS to dump every tenant's rows). NOT the app's runtime role.
  POSTGRES_PASSWORD: REPLACE_ME
  JWT_SECRET: REPLACE_ME_WITH_64_CHAR_RANDOM_VALUE
  # Shared bearer the backend presents to the internal ML inference service.
  # The ML service rejects any request without it (fail-closed). Must be set to
  # the same value in the backend and ml-api deployments.
  ML_SERVICE_TOKEN: REPLACE_ME_WITH_64_CHAR_RANDOM_VALUE
---
apiVersion: v1
kind: Secret
metadata:
  name: sanket-db-url
  namespace: sanket
type: Opaque
stringData:
  # App + worker traffic goes through the PgBouncer pooler (transaction mode).
  # The app sets DB_PGBOUNCER_MODE=true (see production overlay) so asyncpg is
  # pooler-safe. Migrations target the primary directly (postgres-rw) — see
  # migrate-job.yaml — because DDL should not run through a transaction pooler.
  DATABASE_URL: "postgresql+asyncpg://sanket_app:REPLACE_ME@postgres-pooler-rw:5432/sanket"
  # ML uses fewer, longer queries and a sync driver — point it at the primary
  # read-write service directly to avoid pooler/prepared-statement nuances.
  ML_DATABASE_URL: "postgresql://sanket_app:REPLACE_ME@postgres-rw:5432/sanket"
  # Primary-direct URL for the migration Job (bypasses the pooler).
  DATABASE_URL_DIRECT: "postgresql+asyncpg://sanket_app:REPLACE_ME@postgres-rw:5432/sanket"
---
# CloudNativePG application-role credentials. The cluster's initdb `owner`
# (sanket_app) password is read from here. MUST match the password embedded in
# sanket-db-url above. type basic-auth is what CNPG expects.
apiVersion: v1
kind: Secret
metadata:
  name: postgres-app-credentials
  namespace: sanket
type: kubernetes.io/basic-auth
stringData:
  username: sanket_app
  password: REPLACE_ME
---
# CloudNativePG superuser credentials — used by the operator, the migration Job,
# and physical/logical backups (which must bypass RLS to capture every tenant).
# The application NEVER uses this role.
apiVersion: v1
kind: Secret
metadata:
  name: postgres-superuser-credentials
  namespace: sanket
type: kubernetes.io/basic-auth
stringData:
  username: postgres
  password: REPLACE_ME
---
# Firebase authentication. Required by the backend whenever APP_ENV=production:
# config.require_firebase_in_production refuses to boot in prod unless
# FIREBASE_PROJECT_ID (and/or FIREBASE_CREDENTIALS_PATH) is set, because the
# local dev-login fallback must never be active in production.
#
# Provide EITHER:
#   * FIREBASE_PROJECT_ID alone — uses Application Default Credentials
#     (e.g. GKE Workload Identity), no service-account JSON needed; or
#   * FIREBASE_PROJECT_ID + the service-account.json below, mounted into the
#     pod at FIREBASE_CREDENTIALS_PATH.
#
# Staging/dev keep the dev-login fallback by blanking FIREBASE_PROJECT_ID and
# FIREBASE_CREDENTIALS_PATH in their overlay (see overlays/staging), which
# leaves Settings.firebase_enabled == False.
apiVersion: v1
kind: Secret
metadata:
  name: sanket-firebase
  namespace: sanket
type: Opaque
stringData:
  FIREBASE_PROJECT_ID: REPLACE_ME
  # Absolute in-pod path to the mounted service-account JSON (the
  # service-account.json key below). Leave as-is when using Workload Identity
  # and instead remove the volume mount, or blank this to disable file creds.
  FIREBASE_CREDENTIALS_PATH: /var/run/secrets/firebase/service-account.json
  # Firebase service-account JSON, mounted as a file at the path above.
  service-account.json: |
    REPLACE_ME_WITH_FIREBASE_SERVICE_ACCOUNT_JSON

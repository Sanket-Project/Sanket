# Root-level .env (consumed by docker compose). Copy to .env and fill in.
# NEVER commit the real .env — it is gitignored. Rotate any value that leaks.

# ── Core secrets ─────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme
# Generate a strong value: openssl rand -hex 32
# Used to sign the local dev-login fallback tokens (and nothing in prod).
JWT_SECRET=replace-with-64-char-random-secret-before-production
GRAFANA_PASSWORD=sanket

# ── Firebase Authentication ──────────────────────────────────────────────
# Leave BOTH of these blank for local dev: the backend then uses the built-in
# dev-login fallback (POST /api/v1/auth/dev-login) so no Firebase project is
# needed. Set them in staging/production to verify real Firebase ID tokens.
#
# FIREBASE_PROJECT_ID: your Firebase/GCP project id.
# FIREBASE_CREDENTIALS_PATH: path (inside the backend container) to a
#   service-account JSON with the "Firebase Authentication Admin" role.
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_PATH=
# Optional: the web API key, surfaced to the SPA via GET /api/v1/auth/config.
FIREBASE_WEB_API_KEY=

# Number of trusted reverse-proxy hops in front of the API (for correct client
# IP resolution in rate limiting / brute-force lockout). 0 = trust socket peer.
TRUSTED_PROXY_COUNT=1

# ── Frontend (Vite build args) ───────────────────────────────────────────
# Public Firebase web config. Safe to expose in the browser bundle. Leave blank
# for dev to use the dev-login fallback UI.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# ── Optional external signal API keys ────────────────────────────────────
FRED_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
